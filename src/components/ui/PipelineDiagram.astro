---
interface Step {
  label: string;
  sub?: string;
}

interface Props {
  steps: Step[];
  caption?: string;
  ariaLabel?: string;
}

const { steps, caption, ariaLabel } = Astro.props;
const srLabel = ariaLabel ?? `Pipeline: ${steps.map((s) => s.label).join(' then ')}`;
---

<figure class="pipeline-diagram">
  <ol class="pipeline-steps" aria-label={srLabel}>
    {steps.map((step, i) => (
      <li class="pipeline-item">
        <div class="pipeline-step">
          <span class="pipeline-step-label">{step.label}</span>
          {step.sub && <span class="pipeline-step-sub">{step.sub}</span>}
        </div>
        {i < steps.length - 1 && (
          <div class="pipeline-arrow" aria-hidden="true">
            <svg viewBox="0 0 24 24" width="24" height="24">
              <path
                d="M 2 12 L 18 12 M 12 6 L 18 12 L 12 18"
                fill="none"
                stroke="currentColor"
                stroke-width="2"
                stroke-linecap="round"
                stroke-linejoin="round"
              />
            </svg>
          </div>
        )}
      </li>
    ))}
  </ol>
  {caption && <figcaption>{caption}</figcaption>}
</figure>

<style>
  .pipeline-diagram {
    margin: 2rem 0;
  }

  .pipeline-steps {
    display: flex;
    flex-wrap: wrap;
    align-items: stretch;
    justify-content: center;
    gap: 0.5rem;
    padding: 0;
    margin: 0;
    list-style: none;
  }

  .pipeline-item {
    display: flex;
    align-items: stretch;
    gap: 0.5rem;
    flex: 0 0 auto;
  }

  .pipeline-step {
    display: flex;
    flex-direction: column;
    justify-content: center;
    align-items: center;
    padding: 0.75rem 1rem;
    background: var(--color-surface);
    border: 1px solid var(--color-border);
    border-radius: 0.5rem;
    color: var(--color-text);
    font-family: var(--font-sans);
    font-size: 0.875rem;
    text-align: center;
    flex: 0 0 9rem;
    max-width: 14rem;
  }

  .pipeline-step-label {
    font-weight: 500;
  }

  .pipeline-step-sub {
    display: block;
    margin-top: 0.25rem;
    font-size: 0.75rem;
    color: var(--color-text-secondary);
    font-family: var(--font-mono);
  }

  .pipeline-arrow {
    display: flex;
    align-items: center;
    justify-content: center;
    color: var(--color-text-secondary);
    flex: 0 0 auto;
  }

  .pipeline-arrow svg {
    width: 1.5rem;
    height: 1.5rem;
  }

  .pipeline-diagram figcaption {
    margin-top: 1rem;
    font-size: 0.9375rem;
    color: var(--color-text-secondary);
    font-style: italic;
    text-align: center;
    max-width: 45rem;
    margin-inline: auto;
  }

  @media (max-width: 640px) {
    .pipeline-steps {
      flex-direction: column;
      gap: 0;
    }

    .pipeline-item {
      flex-direction: column;
      width: 100%;
    }

    .pipeline-step {
      width: 100%;
      max-width: 100%;
    }

    .pipeline-arrow {
      padding: 0.375rem 0;
    }

    .pipeline-arrow svg {
      transform: rotate(90deg);
    }
  }
</style>

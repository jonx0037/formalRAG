---
interface Props {
  slug: string;
  title: string;
  available: boolean;
}

const { slug, title, available } = Astro.props;
---

{available ? (
  <a
    href={`/topics/${slug}`}
    class="inline-flex items-center gap-1 rounded-full border border-[var(--color-border)] px-3 py-1 text-xs font-[family-name:var(--font-sans)] text-[var(--color-accent)] hover:bg-[var(--color-muted-bg)] transition-colors"
  >
    {title}
  </a>
) : (
  <span class="inline-flex items-center gap-1 rounded-full border border-[var(--color-border)] px-3 py-1 text-xs font-[family-name:var(--font-sans)] text-[var(--color-disabled-text)]">
    {title} <span class="text-[0.65rem]">(coming soon)</span>
  </span>
)}

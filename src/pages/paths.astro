---
import BaseLayout from '../layouts/BaseLayout.astro';
import CurriculumGraph from '../components/viz/CurriculumGraph.tsx';
import TopicCard from '../components/ui/TopicCard.astro';
import { getCollection } from 'astro:content';
import { tracks } from '../data/curriculum';
import graphData from '../data/curriculum-graph.json';
import { synthesizeCrossSiteNodes } from '../lib/synthesizeCrossSiteNodes';

const allTopics = await getCollection('topics');
const publishedTopics = allTopics.filter((t) => t.data.status === 'published');

// Build-time synthesis of cross-site prereq nodes from MDX frontmatter.
// Internal-only edges live in curriculum-graph.json; cross-site edges are
// derived from formalcalculusPrereqs / formalstatisticsPrereqs and merged
// here without ever touching the JSON.
const crossSite = synthesizeCrossSiteNodes(publishedTopics);
const mergedNodes = [...graphData.nodes, ...crossSite.nodes];
const mergedEdges = [...graphData.edges, ...crossSite.edges];

// Group published topics by domain
const publishedByDomain = publishedTopics.reduce<Record<string, typeof publishedTopics>>(
  (acc, t) => {
    if (!acc[t.data.domain]) acc[t.data.domain] = [];
    acc[t.data.domain].push(t);
    return acc;
  },
  {}
);

const difficultyOrder = { foundational: 0, intermediate: 1, advanced: 2 };
---

<BaseLayout title="Curriculum Roadmap" description="A planned roadmap of all content areas on formalRAG">
  <section class="mx-auto max-w-5xl px-6 py-12">
    <h1 class="text-3xl font-semibold font-[family-name:var(--font-sans)] mb-2">Curriculum Roadmap</h1>
    <p class="text-[var(--color-text-secondary)] mb-10 max-w-xl leading-relaxed">
      A planned map of content areas. Published topics are linked; everything else is on the roadmap.
    </p>

    {/* Interactive prerequisite graph — hidden on mobile */}
    <div class="hidden md:block mb-12">
      <p class="text-sm text-[var(--color-text-secondary)] mb-4">
        Explore the full dependency graph, or browse by track below.
      </p>
      <CurriculumGraph client:visible nodes={mergedNodes} edges={mergedEdges} />
    </div>

    <div class="space-y-10">
      {tracks.map((track, idx) => {
        const { domain, label, description, dependsOnFormalML, layer } = track;
        // Widen from the `as const` literal tuple so length comparisons type-check.
        const planned: readonly string[] = track.planned;
        const live = (publishedByDomain[domain] ?? []).sort(
          (a, b) => difficultyOrder[a.data.difficulty] - difficultyOrder[b.data.difficulty]
        );
        const isTrackComplete = planned.length === 0 && live.length > 0;
        // Inject a layer header at every layer transition (and before the very
        // first track). Source of truth for the layer is curriculum.ts, so
        // reordering tracks there auto-relocates the header.
        const isLayerStart = idx === 0 || tracks[idx - 1].layer !== layer;
        const layerAnchor = layer.toLowerCase().replace(/\s+/g, '-');

        return (
          <Fragment>
            {isLayerStart && (
              <h2
                id={layerAnchor}
                class="text-2xl font-bold font-[family-name:var(--font-sans)] tracking-tight pt-4 scroll-mt-24"
              >
                {layer}
              </h2>
            )}
            <div id={domain} class="border-t border-[var(--color-border)] pt-8 scroll-mt-24">
            <div class="flex items-baseline gap-3 mb-1">
              <h3 class="text-lg font-semibold font-[family-name:var(--font-sans)]">{label}</h3>
              {isTrackComplete ? (
                <span class="text-xs font-medium font-[family-name:var(--font-sans)] px-2 py-0.5 rounded-full bg-[var(--color-badge-green-bg)] text-[var(--color-badge-green-text)]">
                  Track complete
                </span>
              ) : live.length > 0 && planned.length > 0 ? (
                <span class="text-xs font-[family-name:var(--font-sans)] text-[var(--color-accent)]">
                  {live.length} published / {planned.length} planned
                </span>
              ) : live.length > 0 ? (
                <span class="text-xs font-[family-name:var(--font-sans)] text-[var(--color-accent)]">
                  {live.length} published
                </span>
              ) : planned.length > 0 ? (
                <span class="text-xs font-[family-name:var(--font-sans)] text-[var(--color-text-secondary)]">
                  {planned.length} planned
                </span>
              ) : null}
            </div>
            <p class="text-sm text-[var(--color-text-secondary)] mb-4 leading-relaxed">{description}</p>

            {dependsOnFormalML && (
              <p class="text-xs text-[var(--color-text-secondary)] mb-4">
                Need the ML foundations?{' '}
                <a
                  href="https://formalml.com"
                  class="text-[var(--color-accent)] hover:underline"
                  target="_blank"
                  rel="noopener noreferrer"
                >
                  formalml.com &rarr;
                </a>
              </p>
            )}

            {live.length > 0 && (
              <div class="grid gap-4 sm:grid-cols-2">
                {live.map((t) => (
                  <TopicCard
                    id={t.id}
                    title={t.data.title}
                    subtitle={t.data.subtitle}
                    abstract={t.data.abstract}
                    difficulty={t.data.difficulty}
                    domain={t.data.domain}
                    prerequisiteCount={t.data.prerequisites.length}
                    showStartHere={t.data.prerequisites.length === 0}
                  />
                ))}
              </div>
            )}

            {planned.length > 0 && (
              <ul class="mt-4 space-y-2">
                {planned.map((title) => (
                  <li class="flex items-center gap-3 opacity-40">
                    <span class="h-1.5 w-1.5 rounded-full border border-current flex-shrink-0" />
                    <span class="text-sm">{title}</span>
                    <span class="text-xs text-[var(--color-text-secondary)]">Planned</span>
                  </li>
                ))}
              </ul>
            )}
          </div>
          </Fragment>
        );
      })}
    </div>

    <div class="mt-16 border-t border-[var(--color-border)] pt-8">
      <h2 class="text-lg font-semibold font-[family-name:var(--font-sans)] mb-2">Building your foundations?</h2>
      <p class="text-sm text-[var(--color-text-secondary)] leading-relaxed max-w-xl">
        Many topics here build directly on machine-learning theory — representation learning,
        information theory, conformal prediction — covered on{' '}
        <a
          href="https://formalml.com"
          class="text-[var(--color-accent)] hover:underline"
          target="_blank"
          rel="noopener noreferrer"
        >
          formalml.com
        </a>. The deeper foundations live on{' '}
        <a
          href="https://formalcalculus.com"
          class="text-[var(--color-accent)] hover:underline"
          target="_blank"
          rel="noopener noreferrer"
        >
          formalcalculus.com
        </a>{' '}
        (linear algebra, optimization, analysis) and{' '}
        <a
          href="https://formalstatistics.com"
          class="text-[var(--color-accent)] hover:underline"
          target="_blank"
          rel="noopener noreferrer"
        >
          formalstatistics.com
        </a>{' '}
        (estimation, testing, calibration) — all with the same geometric-first approach.
      </p>
    </div>
  </section>
</BaseLayout>

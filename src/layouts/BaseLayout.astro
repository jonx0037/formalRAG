---
import Nav from '../components/ui/Nav.astro';
import Footer from '../components/ui/Footer.astro';
import '../styles/global.css';

interface Props {
  title: string;
  description?: string;
  ogImage?: string;
}

const { title, description = 'The mathematics of retrieval-augmented generation', ogImage } = Astro.props;
const canonicalURL = new URL(Astro.url.pathname, Astro.site);
---

<!doctype html>
<html lang="en" class="scroll-smooth">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <script is:inline>
      (function() {
        var t = localStorage.getItem('theme');
        if (!t) t = window.matchMedia('(prefers-color-scheme: dark)').matches ? 'dark' : 'light';
        document.documentElement.setAttribute('data-theme', t);
      })();
    </script>
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="canonical" href={canonicalURL} />

    <title>{title} | formalRAG</title>
    <meta name="description" content={description} />

    <!-- OG -->
    <meta property="og:title" content={`${title} | formalRAG`} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content="article" />
    <meta property="og:url" content={canonicalURL} />
    {ogImage && <meta property="og:image" content={ogImage} />}

    <!-- KaTeX CSS -->
    <link
      rel="stylesheet"
      href="https://cdn.jsdelivr.net/npm/katex@0.16.11/dist/katex.min.css"
      crossorigin="anonymous"
    />

  </head>
  <body class="min-h-screen bg-[var(--color-bg)] text-[var(--color-text)] font-[family-name:var(--font-serif)]">
    <Nav />
    <main>
      <slot />
    </main>
    <Footer />
    <!-- Pagefind search dialog -->
    <div id="search-dialog" class="hidden fixed inset-0 z-50 bg-black/50 flex items-start justify-center pt-20">
      <div class="bg-[var(--color-surface)] rounded-xl shadow-xl w-full max-w-xl mx-6 p-6">
        <div id="search"></div>
      </div>
    </div>
    <link href="/pagefind/pagefind-ui.css" rel="stylesheet" />
    <script src="/pagefind/pagefind-ui.js" is:inline></script>
    <script is:inline>
      window.addEventListener('DOMContentLoaded', () => {
        if (typeof PagefindUI !== 'undefined') {
          new PagefindUI({ element: '#search', showSubResults: true });
        }
        document.getElementById('search-trigger')?.addEventListener('click', () => {
          document.getElementById('search-dialog')?.classList.toggle('hidden');
        });
        document.getElementById('search-dialog')?.addEventListener('click', (e) => {
          if (e.target === e.currentTarget) {
            e.currentTarget.classList.add('hidden');
          }
        });
      });
    </script>
  </body>
</html>
